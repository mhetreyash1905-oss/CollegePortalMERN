# MongoDB connection string (required)
# Local: mongodb://127.0.0.1:27017/college
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/college
MONGODB_URI=

# JWT secret for authentication (required - use a long random string)
JWT_SECRET=

# Frontend URL for CORS (required)
FRONTEND_API_LINK=http://localhost:3000

# Optional: Email service for password resets (Gmail via Nodemailer)
NODEMAILER_EMAIL=
NODEMAILER_PASS=

# Optional: Cloudinary for Lost & Found image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: SendGrid for claim notification emails
SENDGRID_API_KEY=
SENDGRID_FROM=

# Optional: Google Gemini AI assistant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
